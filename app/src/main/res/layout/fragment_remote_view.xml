<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_background">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="15dp"
        android:paddingBottom="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:background="@color/menu_background">

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textSize="20sp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/button_background"
            android:textColor="@color/button_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DingTalk Remote View Config"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌂"
            android:textSize="20sp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:backgroundTint="@color/button_background"
            android:textColor="@color/button_text" />
    </LinearLayout>

    <!-- Settings content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ClientId -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ClientId / AppKey"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_client_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter DingTalk ClientId"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp"
                android:background="@color/card_background"
                android:padding="16dp"
                android:minHeight="56dp"
                android:layout_marginBottom="16dp" />

            <!-- ClientSecret -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ClientSecret / AppSecret"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/card_background"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/et_client_secret"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Enter DingTalk ClientSecret"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="16sp"
                    android:background="@android:color/transparent"
                    android:padding="16dp"
                    android:minHeight="56dp"
                    android:inputType="textPassword" />

                <ImageButton
                    android:id="@+id/btn_toggle_secret_visibility"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_visibility"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle password visibility"
                    android:tint="@color/text_primary"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 保存和测试按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_save_config"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save Config"
                    android:textSize="20sp"
                    android:minHeight="56dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/button_background"
                    android:textColor="@color/button_text" />

                <Button
                    android:id="@+id/btn_test_connection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Test Connection"
                    android:textSize="20sp"
                    android:minHeight="56dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/button_background"
                    android:textColor="@color/button_text" />
            </LinearLayout>

            <!-- 自动启动开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:padding="12dp"
                android:background="@color/card_background">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-start Service"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-connect remote viewing service on startup and auto-reconnect on disconnect"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_auto_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- 连接状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connection Status:"
                    android:textColor="@color/text_secondary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_connection_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disconnected"
                    android:textColor="#FF6666"
                    android:textSize="18sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 启动/Stop Service按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_start_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Service"
                    android:textSize="20sp"
                    android:minHeight="56dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/button_background"
                    android:textColor="@color/button_text" />

                <Button
                    android:id="@+id/btn_stop_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop Service"
                    android:textSize="20sp"
                    android:minHeight="56dp"
                    android:enabled="false"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/button_background"
                    android:textColor="@color/button_text" />
            </LinearLayout>

            <!-- Instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Instructions"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Create an internal app on DingTalk Open Platform\n2. Enable bot capability and configure Stream mode\n3. Fill in ClientId and ClientSecret above\n4. Save config and start service\n5. In DingTalk group, @bot and send "record" command\n6. Device records a 1-minute video and uploads it to the group"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
