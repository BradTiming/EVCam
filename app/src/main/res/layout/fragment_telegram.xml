<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_background">

    <!-- 标题栏（移到 ScrollView 外部） -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/menu_background"
        android:paddingTop="15dp"
        android:paddingBottom="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textSize="20sp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/button_background"
            android:textColor="@color/button_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Telegram Bot Configuration"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌂"
            android:textSize="20sp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:backgroundTint="@color/button_background"
            android:textColor="@color/button_text" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Bot Token -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bot Token"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/card_background"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_bot_token"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter Bot Token (from @BotFather)"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp"
                android:background="@android:color/transparent"
                android:padding="16dp"
                android:minHeight="56dp"
                android:inputType="textPassword" />

            <ImageButton
                android:id="@+id/btn_toggle_token_visibility"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_visibility"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle password visibility"
                android:tint="@color/text_primary"
                android:layout_marginEnd="8dp" />
        </LinearLayout>

        <!-- 允许的 Chat ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Allowed Chat IDs (Optional)"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_allowed_chat_ids"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Allowed Chat IDs (comma-separated, empty = allow all)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"
            android:background="@color/card_background"
            android:padding="16dp"
            android:minHeight="56dp"
            android:layout_marginBottom="16dp" />

        <!-- Reverse proxy API URL (optional) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reverse proxy API URL (optional)"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_api_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alternative API host accessible in your region (empty = official API)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"
            android:background="@color/card_background"
            android:padding="16dp"
            android:minHeight="56dp"
            android:inputType="textUri"
            android:layout_marginBottom="24dp" />

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btn_save_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Config"
            android:textSize="20sp"
            android:minHeight="56dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/button_background"
            android:textColor="@color/button_text" />

        <!-- 自动启动开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="@color/card_background">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-start service"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-connect Telegram bot when app starts"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_auto_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- 连接状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connection Status:"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Not Connected"
                android:textColor="#FF6666"
                android:textSize="18sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 启动/停止服务按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start Service"
                android:textSize="20sp"
                android:minHeight="56dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/button_background"
                android:textColor="@color/button_text" />

            <Button
                android:id="@+id/btn_stop_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop Service"
                android:textSize="20sp"
                android:minHeight="56dp"
                android:enabled="false"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/button_background"
                android:textColor="@color/button_text" />
        </LinearLayout>

        <!-- 使用说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Instructions"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_help_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Open Telegram and find @BotFather
2. Send /newbot to create a bot
3. Get Bot Token and fill it above
4. Save configuration and start service
5. Send commands to the bot:
   • /record or record - record 60-second video
   • /record 30 - record 30-second video
   • /photo or photo - take photo
   • /help - show help
6. Device will execute and upload automatically to Telegram"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
