<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_rounded_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Usage Tips"
            android:textSize="38sp"
            android:textColor="@color/dialog_guide_title"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/dialog_guide_accent"
            android:layout_marginBottom="20dp" />

        <!-- 提示内容1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="①"
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_accent"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Before use, grant all required permissions and configure your vehicle model."
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_content"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 提示内容2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="②"
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_accent"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="If your model is not yet adapted, choose Custom Model and tune it manually. Some bugs are expected."
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_content"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 提示内容3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="③"
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_accent"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="If recorded videos cannot be saved, try changing the recording mode."
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_content"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 提示内容4 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="④"
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_accent"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="After first setup or after updating, if bugs appear, restart the head unit once."
                android:textSize="25sp"
                android:textColor="@color/dialog_guide_content"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 分隔线2 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dialog_guide_divider"
            android:layout_marginBottom="16dp" />

        <!-- 作者信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Author: @greenteacher46. This version is free and open source. Please report any paid resale/commercial abuse."
            android:textSize="20sp"
            android:textColor="@color/dialog_guide_secondary"
            android:lineSpacingExtra="3dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- 打赏支持 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Development takes time and effort. If this project helps you, donations are welcome."
            android:textSize="20sp"
            android:textColor="@color/dialog_guide_accent"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- 二维码图片（尺寸在代码中根据屏幕密度动态设置） -->
        <ImageView
            android:id="@+id/iv_qrcode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:scaleType="fitCenter"
            android:contentDescription="Donation QR Code"
            android:layout_marginBottom="20dp" />

        <!-- 确认按钮 -->
        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/dialog_button_background"
            android:gravity="center"
            android:text="Got it"
            android:textColor="@color/dialog_guide_button_text"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
